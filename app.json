{
  "expo": {
    "name": "CoupleApp",
    "slug": "lexou24",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "coupleapp",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "extra": {
      "eas": {
        "projectId": "01faf6bc-45d6-4b49-b862-9db252a98be6"
      },
      "router": {
        "origin": false
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alemille.appname"
    },
    "android": {
      "package": "com.alemille.appname",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "jsEngine": "hermes"
    },
    "web": {},
    "plugins": [
      "expo-router",
      "react-native-reanimated",
      [
        "expo-notifications",
        {
          "color": "#e94560"
        }
      ]
    ],
    "sdkVersion": "53.0.0",
    "platforms": [
      "ios",
      "android"
    ]
  }
}
