{
  "expo": {
    "name": "CoupleApp",
    "slug": "lexou2",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "coupleapp",
    "extra": {
      "eas": {
        "projectId": "4143129d-ef1d-4d18-a143-098f2bc07a5f"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alemille.appname"
    },
    "android": {
      "package": "com.alemille.appname",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e94560"
        }
      ]
    ]
  }
}
